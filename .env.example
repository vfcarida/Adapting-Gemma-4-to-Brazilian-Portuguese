# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Gemma 4 PT-BR Adaptation — Environment Variables                   ║
# ║  Copy to .env and fill in your credentials                          ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Hugging Face ─────────────────────────────────────────────────────
# Required: gated access to Gemma 4 models and Aurora-PT dataset
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Weights & Biases ─────────────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=gemma4-ptbr-adapt
WANDB_ENTITY=your_wandb_entity_here
# Set to "disabled" to skip W&B logging entirely
# WANDB_MODE=disabled

# ── Paths ────────────────────────────────────────────────────────────
# Root directory for all outputs (checkpoints, merged models, logs)
OUTPUT_DIR=./output
# Hugging Face cache directory (datasets, models)
CACHE_DIR=./cache
# Directory for evaluation result JSON files
EVAL_OUTPUT_DIR=./reports/eval_results
# Directory for training log JSONL files
TRAIN_LOG_DIR=./reports/training_logs

# ── Model IDs ────────────────────────────────────────────────────────
# Pilot model (small, for rapid iteration)
PILOT_MODEL_ID=google/gemma-4-E4B
# Main model (MoE, production target)
MAIN_MODEL_ID=google/gemma-4-26B-A4B
# Instruct variants (used in residual merge)
PILOT_INSTRUCT_ID=google/gemma-4-E4B-it
MAIN_INSTRUCT_ID=google/gemma-4-26B-A4B-it

# ── Dataset IDs ──────────────────────────────────────────────────────
AURORA_DATASET_ID=Itau-Unibanco/Aurora-PT
# English replay mix source (high-quality subset)
EN_REPLAY_DATASET_ID=HuggingFaceFW/fineweb-edu

# ── Training ─────────────────────────────────────────────────────────
GLOBAL_SEED=42
# Number of GPUs (auto-detected if not set)
# NUM_GPUS=4

# ── Evaluation Baselines ─────────────────────────────────────────────
BASELINE_MODELS=CEIA-UFG/Gemma-3-Gaia-PT-BR-4b-it,maritaca-ai/sabia-7b,Polygl0t/Tucano2-qwen-3.7B-Instruct
